# ============================================
# InstaPost AI - Variáveis de Ambiente (Produção)
# ============================================
# Use no painel do Coolify → Environment Variables

# === URLs Públicas ===
# Substitua SEU_IP pelo IP da sua VPS
# Quando tiver domínio, troque por https://api.seudominio.com.br etc.
NEXT_PUBLIC_API_URL=http://SEU_IP:3001
FRONTEND_URL=http://SEU_IP:3000
MINIO_PUBLIC_URL=http://SEU_IP:9000

# === Banco de Dados (Postgres) ===
DB_PASSWORD=GERE_UMA_SENHA_FORTE
POSTGRES_USER=instapost
POSTGRES_DB=instapost

# === Redis ===
REDIS_PASSWORD=GERE_UMA_SENHA_FORTE

# === Instagram Graph API ===
INSTAGRAM_ACCESS_TOKEN=seu_token_aqui
INSTAGRAM_USER_ID=seu_ig_user_id

# === Nano Banana (Geração de Imagens via Gemini) ===
NANO_BANANA_API_KEY=sua_api_key

# === Telegram Bot ===
TELEGRAM_BOT_TOKEN=seu_bot_token
TELEGRAM_ALLOWED_CHAT_IDS=123456789

# === MinIO (Storage S3) ===
MINIO_ACCESS_KEY=GERE_UM_ACCESS_KEY
MINIO_SECRET_KEY=GERE_UM_SECRET_KEY

# === Auth ===
JWT_SECRET=GERE_UM_SECRET_LONGO

# === MCP Server ===
MCP_AUTH_TOKEN=GERE_UM_TOKEN
