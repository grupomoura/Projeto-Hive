FROM python:3.12-slim

# Install ffmpeg
RUN apt-get update && \
    apt-get install -y --no-install-recommends ffmpeg && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Install Python dependencies
COPY scripts/video/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy scripts
COPY scripts/video/ ./scripts/

# Work directory for video processing
RUN mkdir -p /tmp/instapost-videos

CMD ["echo", "Video worker ready. Scripts in /app/scripts/"]
